# MongoDB
MONGO_URI=

# JWT
JWT_SECRET=
JWT_SESSION_EXPIRES_IN=2h
JWT_REMEMBER_EXPIRES_IN=7d
AUTH_COOKIE_NAME=token
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

# Server
PORT=5000
NODE_ENV=development

# Admin seed (first boot)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# CORS
CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173

# Cloudinary (REQUIRED for media uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=

# SMTP (for sending OTP emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Modern Wedding Studios <your-email@gmail.com>"
EMAIL_DEV_MODE=false
