# MongoDB
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname?appName=YourApp

# JWT
JWT_SECRET=generate-a-64-char-hex-secret
JWT_SESSION_EXPIRES_IN=2h
JWT_REMEMBER_EXPIRES_IN=7d
AUTH_COOKIE_NAME=token
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

# Server
PORT=5000
NODE_ENV=production

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-password

# Client URL (for CORS and reset links)
CLIENT_URL=https://your-frontend-domain.com
CLIENT_URLS=https://your-frontend-domain.com,http://localhost:5173,http://127.0.0.1:5173

# Cloudinary (REQUIRED for media uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Google OAuth (for user login)
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id

# SMTP (for sending OTP emails)
# Gmail: use smtp.gmail.com, port 587, your email as user, 16-digit app password as pass
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-digit-app-password
SMTP_FROM="Modern Wedding Studios <your-email@gmail.com>"
EMAIL_DEV_MODE=false

# Client build variables
VITE_API_URL=http://localhost:5000/api/v1
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_ADMIN_EMAIL=admin@example.com
